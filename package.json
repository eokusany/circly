{
  "name": "reeco",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "server"
  ],
  "scripts": {
    "mobile": "npm --workspace apps/mobile start",
    "server": "npm --workspace server dev",
    "lint": "npm --workspace apps/mobile run lint && npm --workspace server run lint",
    "typecheck": "npm --workspace apps/mobile run typecheck && npm --workspace server run typecheck",
    "test": "npm --workspace server run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5"
  }
}
